#!/bin/bash

# Rolf Niepraschk (Rolf.Niepraschk@gmx.de)

# Installiert eine neue Version  vom zugehörigen GIT-Repositorium
# und lädt den Server-Prozess neu.

# Aufruf als root (auf dem Server!):
#
# ./update_from_git
#

# Abbrechen bei Fehlern, ungesetzten Variablen oder Fehlern in Pipes
set -euo pipefail

PROJECT="relayServer"
THIS_USER="vaclab"
GIT_USER="vaclab"
GITLAB_URL="git@u99145.bs.ptb.de:vaclab/${PROJECT}.git"
TARGET_DIR="$(pwd)"

SCRIPT_NAME=$(basename "$0")

# 1. Validierung des Verzeichnisses
if [ ! -f "$SCRIPT_NAME" ]; then
    echo "Error: Script must be executed in the target folder."
    exit 1
fi

echo "* Start update for project: ${PROJECT}"

# 2. Temporäres Verzeichnis erstellen
TEMP_DIR=$(mktemp -d)
chown "${GIT_USER}:" "${TEMP_DIR}"

# 3. Git Clone als GIT_USER (nur der neueste Stand ohne Historie)
sudo -u "${GIT_USER}" bash <<EOF
    set -e
    git clone --depth 1 --quiet "${GITLAB_URL}" "${TEMP_DIR}/${PROJECT}"
EOF

# 4. Sync ins Zielverzeichnis
# -a: Archiv-Modus (Rechte, Zeiten)
# --delete: Löscht Dateien im Ziel, die im Git nicht mehr existieren
# --exclude='.git': Muss dann nicht extra gelöscht werden.
echo "* Synchronize files..."
rsync -a --exclude='.git' "${TEMP_DIR}/${PROJECT}/" "${TARGET_DIR}/"

# 5. Berechtigungen im Ziel geradeziehen
chown -R "${THIS_USER}:" "${TARGET_DIR}"

# 6. Aufräumen
rm -rf "${TEMP_DIR}"

# 7. Systemd-Service neustarten
echo "* Restart the service..."
systemctl daemon-reload
if systemctl is-active --quiet "${PROJECT}.service"; then
    systemctl restart "${PROJECT}.service"
else
    systemctl start "${PROJECT}.service"
fi

echo "✓ Update successfully completed."
